{
  "expo": {
    "name": "SIBANTEN",
    "slug": "SIBANTEN",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "sibanten",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.prtmaar.SIBANTEN",
      "gradleProperties": {
        "newArchEnabled": "true"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Izinkan SIBANTEN mengakses kamera untuk mengambil foto laporan."
        }
      ],
      [
        "expo-location",
        {
          "locationPermission": "Izinkan SIBANTEN mengakses lokasi untuk menentukan titik koordinat laporan."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a1ea4643-ec9f-4536-8f13-c2539df2f4d1"
      }
    }
  }
}
